{
  "name": "@zazigv2/local-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Local agent daemon — connects to Supabase Realtime, executes tmux sessions",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "@zazigv2/shared": "*",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "*"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
