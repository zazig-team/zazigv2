{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@zazigv2/shared": ["./packages/shared/src/index.ts"],
      "@zazigv2/orchestrator": ["./packages/orchestrator/src/index.ts"],
      "@zazigv2/local-agent": ["./packages/local-agent/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "packages/*/dist"]
}
